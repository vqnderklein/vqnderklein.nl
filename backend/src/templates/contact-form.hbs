<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>New Contact Form Submission</title>
  </head>

  <body style="font-family: Arial, sans-serif; background-color: #f6f6f6; padding: 20px;">
    
    <div style="max-width: 600px; margin: auto; background: #ffffff; padding: 20px; border-radius: 8px;">
      
      <h2 style="color: #333;">New Contact Form Message</h2>

      <p style="font-size: 16px; color: #555;">
        {{firstName}} has sent you a message
      </p>

      <hr />

      <p><strong>Subject:</strong> {{subject}}</p>
      <p><strong>Name:</strong> {{firstName}} {{lastName}}</p>
      <p><strong>Aanhef:</strong> {{title}}</p>
      <p><strong>Email:</strong> {{email}}</p>

      <hr />

      <h3 style="margin-bottom: 5px;">Message:</h3>
      <p style="white-space: pre-line; background: #f9f9f9; padding: 10px; border-radius: 5px;">
        {{message}}
      </p>

      <hr />

      <p style="font-size: 12px; color: #999;">
        This email was automatically generated from the contact form on your website. Please do not reply to this email directly.
      </p>

    </div>

  </body>
</html>
